// Prisma schema for bensden.xyz
// Database: Neon (serverless PostgreSQL) — https://neon.tech
// Connect via Vercel integration: https://vercel.com/integrations/neon
// Set DATABASE_URL in .env.local after connecting

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PostView {
  slug      String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
